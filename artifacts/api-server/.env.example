# Backend — copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Local default: postgres://localhost/threat_legion
# With auth:     postgres://user:password@localhost/threat_legion
DATABASE_URL=postgres://localhost/threat_legion

# GitHub token — optional, increases API rate limit from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_your_token_here
